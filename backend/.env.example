# Database
DATABASE_URL="postgresql://bookswap:password@localhost:5432/bookswap_dev"

# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Email (for OTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# WhatsApp (Gupshup)
GUPSHUP_API_KEY=your-gupshup-api-key
GUPSHUP_APP_NAME=BookSwap

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3001,http://localhost:8081

# Dev mode — set to true ONLY in development to use hardcoded OTP (123456)
# DEV_OTP_MODE=true
