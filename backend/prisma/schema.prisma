generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Users (Parents)
model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  phone         String    @unique
  city          String
  address       String?
  schoolId      String?
  school        School?   @relation(fields: [schoolId], references: [id])
  board         Board?
  isVerified    Boolean   @default(false)
  isAdmin       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  children      Child[]
  listings      Listing[]
  requests      Request[]
  sellerDeals   Deal[]    @relation("Seller")
  buyerDeals    Deal[]    @relation("Buyer")
  notifications Notification[]

  @@index([city, board])
}

// Children (linked to parent)
model Child {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String?
  gender       String?
  currentClass Int      // 1-12
  schoolId     String?
  school       School?  @relation(fields: [schoolId], references: [id])
  createdAt    DateTime @default(now())

  @@index([userId, currentClass])
}

// Schools (master data)
model School {
  id         String   @id @default(uuid())
  name       String
  city       String
  board      Board
  address    String?
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())

  users      User[]
  children   Child[]
  listings   Listing[]
  requests   Request[]

  @@index([city, board])
}

// Book/Stationery Listings
model Listing {
  id             String        @id @default(uuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  title          String
  description    String?
  category       Category
  board          Board?
  class          Int?
  subject        String?
  schoolId       String?
  school         School?       @relation(fields: [schoolId], references: [id])
  city           String
  yearOfPurchase Int?
  condition      BookCondition
  buyingPrice    Float?        // Original purchase price / MRP
  sellingPrice   Float         // Asking price
  status         ListingStatus @default(PENDING_APPROVAL)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  items          ListingItem[]
  images         ListingImage[]
  deals          Deal[]

  @@index([category, board, class, city, status])
  @@index([schoolId, status])
  @@index([sellingPrice])
}

// Book Items (for multi-book sets)
model ListingItem {
  id         String         @id @default(uuid())
  listingId  String
  listing    Listing        @relation(fields: [listingId], references: [id], onDelete: Cascade)
  subject    String
  title      String?
  publisher  String?
  condition  BookCondition?
  createdAt  DateTime       @default(now())

  images     ListingImage[]
}

// Listing Images
model ListingImage {
  id            String       @id @default(uuid())
  listingId     String
  listing       Listing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingItemId String?
  listingItem   ListingItem? @relation(fields: [listingItemId], references: [id])
  imageType     ImageType?
  imageUrl      String
  createdAt     DateTime     @default(now())
}

// Book Requests (unfulfilled book needs)
model Request {
  id           String        @id @default(uuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  board        Board
  class        Int
  subjects     String[]
  schoolId     String?
  school       School?       @relation(fields: [schoolId], references: [id])
  city         String
  maxPrice     Float?
  status       RequestStatus @default(OPEN)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([board, class, city, status])
}

// Deals (buyer requests to purchase a listing)
model Deal {
  id            String     @id @default(uuid())
  listingId     String
  listing       Listing    @relation(fields: [listingId], references: [id])
  sellerId      String
  seller        User       @relation("Seller", fields: [sellerId], references: [id])
  buyerId       String
  buyer         User       @relation("Buyer", fields: [buyerId], references: [id])
  agreedPrice   Float
  status        DealStatus @default(PENDING)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([sellerId, status])
  @@index([buyerId, status])
}

// Notifications
model Notification {
  id        String              @id @default(uuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id])
  type      NotificationType
  channel   NotificationChannel
  title     String?
  body      String?
  data      Json?
  isRead    Boolean             @default(false)
  sentAt    DateTime            @default(now())
}

// OTP Storage
model Otp {
  id        String   @id @default(uuid())
  email     String
  otp       String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, otp])
}

// Enums
enum Board {
  CBSE
  ICSE
  STATE
  IB
  IGCSE
}

enum Category {
  BOOK
  STATIONERY
}

enum BookCondition {
  HARDLY_USED
  WELL_MAINTAINED
  MARKER_USED
  STAINS
  TORN_PAGES
}

enum ListingStatus {
  PENDING_APPROVAL
  ACTIVE
  SOLD
  REJECTED
  CANCELLED
}

enum RequestStatus {
  OPEN
  MATCHED
  FULFILLED
  CANCELLED
}

enum DealStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
  CANCELLED
}

enum ImageType {
  FRONT
  BACK
  MIDDLE
}

enum NotificationType {
  LISTING_APPROVED
  LISTING_REJECTED
  NEW_MATCH_FOR_REQUEST
  DEAL_REQUESTED
  DEAL_ACCEPTED
  DEAL_COMPLETED
  DEAL_CANCELLED
}

enum NotificationChannel {
  PUSH
  WHATSAPP
  EMAIL
}
